{
  "info": {
    "_postman_id": "financial-platform-api",
    "name": "Financial Transactions Platform",
    "description": "API collection for Financial Transactions Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & General",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if API is running"
          },
          "response": []
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Welcome endpoint"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user123\",\n  \"description\": \"Grocery shopping\",\n  \"amount\": 50.99,\n  \"transaction_type\": \"expense\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"]
            },
            "description": "Create a new transaction (requires auth)"
          },
          "response": []
        },
        {
          "name": "Get All User Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions?skip=0&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get all transactions for current user"
          },
          "response": []
        },
        {
          "name": "Get Single Transaction",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1"]
            },
            "description": "Get a specific transaction by ID"
          },
          "response": []
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\",\n  \"amount\": 75.50,\n  \"transaction_type\": \"expense\",\n  \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions/1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1"]
            },
            "description": "Update a transaction"
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1"]
            },
            "description": "Delete a transaction"
          },
          "response": []
        },
        {
          "name": "Get Transaction Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions-summary",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions-summary"]
            },
            "description": "Get summary statistics for user transactions (income, expenses, balance)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Transactions (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/all-transactions?skip=0&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "all-transactions"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get all transactions from all users (admin only)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "test-token-user",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "test-token-admin",
      "type": "string"
    }
  ]
}
